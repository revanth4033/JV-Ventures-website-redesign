// JV Ventures — custom CMS schema (Prisma + Postgres)
// Page content is stored as structured JSON that matches the frontend's
// content/types.ts shapes, so the public data layer is a near-passthrough and
// the admin forms map 1:1 to fields.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URI")
}

/// Singletons: siteSettings, homePage, aboutPage. `data` holds the full shape.
model Singleton {
  key       String   @id
  data      Json // the published content the public site renders
  draft     Json? // unpublished edits awaiting publish/schedule
  publishAt DateTime? // when a scheduled draft should go live (cron)
  updatedAt DateTime @updatedAt

  @@index([publishAt]) // the scheduled-publish cron scans by this
}

/// One row per platform. Scalars for listing/sorting; `data` holds full content.
model Platform {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  order     Int      @default(0)
  name      String
  sector    String
  data      Json
  draft     Json?
  publishAt DateTime?
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([publishAt]) // the scheduled-publish cron scans by this
}

/// Uploaded / referenced media. URL is what the site renders.
model Media {
  id        Int      @id @default(autoincrement())
  url       String   @unique
  alt       String   @default("")
  filename  String
  width     Int?
  height    Int?
  mime      String   @default("")
  hash      String? // sha256 of the bytes, for duplicate detection
  folder    String   @default("") // optional organisational folder
  tags      String[] @default([]) // free-form tags for filtering
  createdAt DateTime @default(now())

  @@index([hash])
  @@index([folder])
}

/// CMS users.
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String   @default("")
  role         String   @default("editor") // admin | editor
  tokenVersion Int      @default(0) // bumped to invalidate all existing JWTs for this user
  createdAt    DateTime @default(now())
}

/// Durable failed-login throttle (brute-force protection), keyed by source IP
/// (keying on IP, not email, avoids an account-lockout DoS).
model LoginAttempt {
  key      String   @id
  fails    Int      @default(0)
  windowAt DateTime @default(now())
}

/// Append-only audit trail: who changed what, when.
model AuditLog {
  id        Int      @id @default(autoincrement())
  userEmail String   @default("")
  entity    String // singleton key, "platform:<slug>", or "media:<id>"
  label     String   @default("") // human-friendly target name
  action    String // create | update | delete | restore
  at        DateTime @default(now())

  @@index([at])
}

/// Contact-form submissions. Persisted so an enquiry is never silently lost;
/// viewable via Prisma Studio / an admin view.
model Enquiry {
  id        Int      @id @default(autoincrement())
  enquiry   String   @default("") // selected enquiry type
  firstName String
  lastName  String   @default("")
  email     String
  phone     String   @default("")
  company   String   @default("")
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// Point-in-time content snapshot for version history + one-click rollback.
model Revision {
  id        Int      @id @default(autoincrement())
  entity    String // singleton key or "platform:<slug>"
  label     String   @default("")
  data      Json
  userEmail String   @default("")
  at        DateTime @default(now())

  @@index([entity, at])
}
