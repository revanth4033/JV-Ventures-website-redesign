# ── Database ─────────────────────────────────────────────
# Local dev: the Postgres container in docker-compose.yml
# Production: replace with your managed Postgres (Neon/Supabase/RDS) URL
DATABASE_URI=postgres://jv:jv_dev_password@localhost:5439/jv_ventures

# ── Payload ──────────────────────────────────────────────
PAYLOAD_SECRET=replace_with_a_long_random_string

# ── Public site ──────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Object storage (optional in dev) ─────────────────────
# Set these for Cloudflare R2 / AWS S3 to store media in a bucket.
# Leave blank to use local disk (./media) during development.
# S3_BUCKET=
# S3_ENDPOINT=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ── Content source ───────────────────────────────────────
# Which CMS backs the public site. Defaults to the custom (Prisma) source when
# unset; set to "sanity" to read content from Sanity instead.
CONTENT_SOURCE=custom

# ── Sanity (only needed when CONTENT_SOURCE=sanity, or to use /studio) ────
# Public project id — exposed to the browser so the embedded Studio can connect.
NEXT_PUBLIC_SANITY_PROJECT_ID=
# Dataset name (the integration assumes "production").
SANITY_DATASET=production
# Server-only token with write access — used by the migration script to seed
# content. Never expose this to the browser.
SANITY_WRITE_TOKEN=
