# ── Database ─────────────────────────────────────────────
# Local dev: the Postgres container in docker-compose.yml
# Production: replace with your managed Postgres (Neon/Supabase/RDS) URL
DATABASE_URI=postgres://jv:jv_dev_password@localhost:5439/jv_ventures

# ── Auth ─────────────────────────────────────────────────
# Secret used to sign admin session JWTs. REQUIRED outside local `next dev` —
# the app refuses to boot without it (so a deploy can't silently use a known
# constant). PAYLOAD_SECRET is still read as a fallback for older deployments.
AUTH_SECRET=replace_with_a_long_random_string

# ── Cron ─────────────────────────────────────────────────
# Bearer token Vercel Cron sends to /api/cron/publish. REQUIRED — the endpoint
# is disabled (503) when unset, so it can never be triggered anonymously.
CRON_SECRET=replace_with_a_long_random_string

# ── Public site ──────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Maps ─────────────────────────────────────────────────
# Mapbox public access token for the Contact page map (https://account.mapbox.com).
# If unset, the Contact page falls back to plain office address cards (no map).
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Object storage (optional in dev) ─────────────────────
# Set these for Cloudflare R2 / AWS S3 to store media in a bucket.
# Leave blank to use local disk (./media) during development.
# S3_BUCKET=
# S3_ENDPOINT=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
